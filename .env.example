# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=equipment
DB_PASSWORD=equipment
DB_NAME=equipment_api

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Server
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Docker (optional)
RUN_MIGRATIONS=true

# Redis (optional — enable with: docker compose --profile redis up)
REDIS_URL=redis://localhost:6379
